# Frontend Environment Variables
# Copy this to .env and update with your actual URLs

# Backend API URL (FastAPI server)
VITE_BACKEND_URL=https://biovault-backend-d13a.onrender.com

# Public app URL (used for share links)
VITE_PUBLIC_URL=https://biovault-app.onrender.com

# Supabase Configuration (if using local backend)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# For development
# VITE_BACKEND_URL=http://localhost:8000
# VITE_PUBLIC_URL=http://localhost:5173
