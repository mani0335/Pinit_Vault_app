<?xml version='1.0' encoding='utf-8'?>
<widget id="com.biovault.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>PINIT Vault</name>
    <description>A digital identity vault with biometric authentication</description>
    <author email="support@pinit.app" href="https://pinit.app">PINIT Vault Team</author>
    
    <!-- Initial page -->
    <content src="index.html" />
    
    <!-- Default permissions -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <!-- Android-specific preferences -->
    <platform name="android">
        <allow-intent href="market:*" />
        
        <!-- Biometric permissions - CRITICAL for fingerprint -->
        <uses-permission android:name="android.permission.USE_FINGERPRINT" />
        <uses-permission android:name="android.permission.USE_BIOMETRIC" />
        <uses-permission android:name="android.permission.BIOMETRIC" />
        
        <!-- Camera permissions -->
        <uses-permission android:name="android.permission.CAMERA" />
        
        <!-- Storage permissions -->
        <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
        <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
        <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
        
        <!-- Internet permissions -->
        <uses-permission android:name="android.permission.INTERNET" />
    </platform>
    
    <!-- CRITICAL PLUGINS for biometric authentication -->
    <!-- ✅ Fingerprint/Biometric detection and authentication -->
    <plugin name="cordova-plugin-fingerprint-aio" spec="^6.0.1">
        <variable name="FACEID_USAGE_DESCRIPTION" value="This app uses face recognition for secure authentication" />
    </plugin>
    
    <!-- ✅ Runtime permission handling for Android 6+ -->
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />
    
    <!-- ✅ File system access for storing biometric data -->
    <plugin name="cordova-plugin-file" spec="^8.0.0" />
    
    <!-- Device info -->
    <plugin name="cordova-plugin-device" spec="^2.1.0" />
    
    <!-- Social sharing (optional, currently used) -->
    <plugin name="cordova-plugin-x-socialsharing" spec="^6.0.4" />
    
    <!-- Preferences -->
    <preference name="orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="ShowTitle" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="loglevel" value="DEBUG" />
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
</widget>
